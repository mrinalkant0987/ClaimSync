    <bpmn:sequenceFlow id="Flow_extract_to_analysisjoin" sourceRef="Task_WF_Extract" targetRef="Gw_AnalysisJoin" />
    <bpmn:sequenceFlow id="Flow_analysis_to_docsgw" sourceRef="Task_AG_Analysis" targetRef="Gw_DocsComplete" />
    <bpmn:sequenceFlow id="Flow_docs_true" sourceRef="Gw_DocsComplete" targetRef="Gw_ValidationsJoin" />
    <bpmn:sequenceFlow id="Flow_sendmissing_to_increment" sourceRef="Task_WF_SendMissing" targetRef="Task_IncrementDocCount" />
    <bpmn:sequenceFlow id="Flow_increment_to_maxgw" sourceRef="Task_IncrementDocCount" targetRef="Gw_MaxAttempts" />
    <bpmn:sequenceFlow id="Flow_max_exceeded" sourceRef="Gw_MaxAttempts" targetRef="Task_HITL_DocEscalation">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js: vars.Var_DocRequestCount &gt;= 3</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_docescalation_to_validjoin" sourceRef="Task_HITL_DocEscalation" targetRef="Gw_ValidationsJoin" />
    <bpmn:sequenceFlow id="Flow_validjoin_to_validations" sourceRef="Gw_ValidationsJoin" targetRef="Task_WF_Validations" />
    <bpmn:sequenceFlow id="Flow_risk_low" sourceRef="Gw_RiskLevel" targetRef="Task_AG_Decision_Low" />
    <bpmn:sequenceFlow id="Flow_decision_low_to_finaljoin" sourceRef="Task_AG_Decision_Low" targetRef="Gw_FinalSummaryJoin" />
    <bpmn:sequenceFlow id="Flow_finalsummary_to_update" sourceRef="Task_AG_FinalSummary" targetRef="Task_WF_UpdateRecord" />
    <bpmn:sequenceFlow id="Flow_update_to_archive" sourceRef="Task_WF_UpdateRecord" targetRef="Task_WF_Archive" />
    <bpmn:sequenceFlow id="Flow_archive_to_end" sourceRef="Task_WF_Archive" targetRef="Event_end" />
    <bpmn:sequenceFlow id="Flow_valid_false" sourceRef="Gw_SubmissionValid" targetRef="Task_HITL_Submission">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js: vars.Var_SubmissionValid === false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_hitl_sub_to_initjoin" sourceRef="Task_HITL_Submission" targetRef="Gw_InitJoin" />
    <bpmn:sequenceFlow id="Flow_docs_false" sourceRef="Gw_DocsComplete" targetRef="Task_WF_SendMissing">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js: vars.Var_DocumentsComplete === false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_max_ok" sourceRef="Gw_MaxAttempts" targetRef="Gw_AnalysisJoin" />
    <bpmn:sequenceFlow id="Flow_risk_medium" sourceRef="Gw_RiskLevel" targetRef="Task_AG_Decision_Med">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js: vars.Var_FraudRiskLevel === "medium"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_decision_med_to_reviewer" sourceRef="Task_AG_Decision_Med" targetRef="Task_HITL_Reviewer" />
    <bpmn:sequenceFlow id="Flow_reviewer_to_outcome" sourceRef="Task_HITL_Reviewer" targetRef="Gw_ReviewerOutcome" />
    <bpmn:sequenceFlow id="Flow_risk_high" sourceRef="Gw_RiskLevel" targetRef="Task_AG_Decision_High">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js: vars.Var_FraudRiskLevel === "high"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_decision_high_to_fraudspec" sourceRef="Task_AG_Decision_High" targetRef="Task_HITL_FraudSpec" />
    <bpmn:sequenceFlow id="Flow_fraudspec_to_outcome" sourceRef="Task_HITL_FraudSpec" targetRef="Gw_ReviewerOutcome" />
    <bpmn:sequenceFlow id="Flow_outcome_proceed" sourceRef="Gw_ReviewerOutcome" targetRef="Gw_FinalSummaryJoin" />
    <bpmn:sequenceFlow id="Flow_outcome_rework" sourceRef="Gw_ReviewerOutcome" targetRef="Task_ResetDocCount">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js: vars.Var_HITLOutcome === "returned_for_rework"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_reset_to_analysisjoin" sourceRef="Task_ResetDocCount" targetRef="Gw_AnalysisJoin" />
  </bpmn:process>
