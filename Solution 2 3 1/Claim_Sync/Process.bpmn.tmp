      <bpmn:incoming>Flow_reset_to_analysisjoin</bpmn:incoming>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_AG_Analysis" name="AG_Claim_Analysis_Core">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartAgentJob" version="v1" />
          <uipath:context>
            <uipath:input name="name" value="=bindings.Bind_Analysis_Name" />
            <uipath:input name="folderPath" value="=bindings.Bind_Analysis_Folder" />
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"claim_id":{"type":"string"},"document_text_bundle":{"type":"string"},"extraction_notes":{"type":"string"},"knowledge_bundle":{"type":"string"},"knowledge_quality_hint":{"type":"string"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"claim_id":"=vars.Var_ClaimId","document_text_bundle":"=vars.Var_DocTextBundle","extraction_notes":"=vars.Var_ExtractionNotes","knowledge_bundle":"=js: (function(){try{var r=JSON.parse(vars.Var_JobResponse||'{}');return r.out_knowledge_bundle||'';}catch(e){return'';}})()","knowledge_quality_hint":"=js: (function(){try{var r=JSON.parse(vars.Var_JobResponse||'{}');return r.out_knowledge_quality_hint||'KNOWLEDGE_LOAD_FAILED';}catch(e){return'KNOWLEDGE_LOAD_FAILED';}})()"}]]></uipath:input>
          <uipath:output name="Process response" type="Orchestrator.RunJob" var="Var_AnalysisResult" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_analysis_to_docsgw</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gw_DocsComplete" name="Documents Complete?" default="Flow_docs_true">
