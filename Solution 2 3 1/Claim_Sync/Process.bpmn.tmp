          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"claim_id":"=vars.Var_ClaimId","document_text_bundle":"=vars.Var_DocTextBundle","claim_category":"=js: (function(){try{var r=JSON.parse(vars.Var_AnalysisResult||'{}');return r.category||'';}catch(e){return'';}})()","extracted_data":"=vars.Var_ExtractedData","validationResults":"=vars.Var_ValidationResults","knowledge_bundle":"=js: (function(){try{var r=JSON.parse(vars.Var_JobResponse||'{}');return r.out_knowledge_bundle||'';}catch(e){return'';}})()"}]]></uipath:input>
