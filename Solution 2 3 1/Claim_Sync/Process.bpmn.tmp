    <bpmn:scriptTask id="Task_IncrementDocCount" name="Increment Doc Request Count" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
          <uipath:context>
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"args":{"type":"string"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"args":null}]]></uipath:input>
          <uipath:output name="DocRequestCount" type="number" source="=result.response" var="Var_DocRequestCount" />
        </uipath:mapping>
        <uipath:scriptVersion value="v3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_sendmissing_to_increment</bpmn:incoming>
      <bpmn:outgoing>Flow_increment_to_maxgw</bpmn:outgoing>
      <bpmn:script><![CDATA[return { response: (docRequestCount || 0) + 1 };]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:exclusiveGateway id="Gw_MaxAttempts" name="Max Attempts?" default="Flow_max_ok">
      <bpmn:incoming>Flow_increment_to_maxgw</bpmn:incoming>
      <bpmn:outgoing>Flow_max_exceeded</bpmn:outgoing>
      <bpmn:outgoing>Flow_max_ok</bpmn:outgoing>
