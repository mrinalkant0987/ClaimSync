      <bpmn:outgoing>Flow_docs_true</bpmn:outgoing>
      <bpmn:outgoing>Flow_docs_false</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_WF_SendMissing" name="WF_Send_Missing_Document_Request">
