      <bpmn:incoming>Flow_decision_med_to_reviewer</bpmn:incoming>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_AG_Decision_High" name="AG_Decision_Support (High)">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartAgentJob" version="v1" />
          <uipath:context>
            <uipath:input name="name" value="=bindings.Bind_Decision_Name" />
            <uipath:input name="folderPath" value="=bindings.Bind_Decision_Folder" />
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"claim_id":{"type":"string"},"analysis_result_json":{"type":"string"},"fraud_risk_json":{"type":"string"},"knowledge_bundle":{"type":"string"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"claim_id":"=vars.Var_ClaimId","analysis_result_json":"=vars.Var_AnalysisResult","fraud_risk_json":"=vars.Var_FraudRiskResult","knowledge_bundle":"=js: (function(){try{var r=JSON.parse(vars.Var_JobResponse||'{}');return r.out_knowledge_bundle||'';}catch(e){return'';}})()"}]]></uipath:input>
          <uipath:output name="Process response" type="Orchestrator.RunJob" var="Var_DecisionResult" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_risk_high</bpmn:incoming>
      <bpmn:outgoing>Flow_decision_high_to_fraudspec</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_HITL_FraudSpec" name="HITL Fraud Specialist">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Actions.HITL" version="v1" />
          <uipath:context>
            <uipath:input name="appId" value="" />
            <uipath:input name="appVersion" value="" />
            <uipath:input name="actions" value="" />
            <uipath:input name="key" value="" />
            <uipath:input name="taskTitle" value="Fraud Specialist Review Required" />
          </uipath:context>
          <uipath:output name="Process response" type="Actions.HITL" var="Var_HITLOutcome" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_decision_high_to_fraudspec</bpmn:incoming>
    </bpmn:userTask>
    <bpmn:scriptTask id="Task_ResetDocCount" name="Reset Doc Request Count" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
          <uipath:context>
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"args":{"type":"string"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"args":null}]]></uipath:input>
          <uipath:output name="DocRequestCount" type="number" source="=result.response" var="Var_DocRequestCount" />
        </uipath:mapping>
        <uipath:scriptVersion value="v3" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_reset_to_analysisjoin</bpmn:outgoing>
      <bpmn:script><![CDATA[return { response: 0 };]]></bpmn:script>
    </bpmn:scriptTask>
