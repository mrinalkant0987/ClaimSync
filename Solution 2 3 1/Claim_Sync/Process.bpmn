    <bpmn:sequenceFlow id="edge_Task_WF_Monitor-Task_WF_InitializeHZw9MP" sourceRef="Task_WF_Monitor" targetRef="Task_WF_Initialize" />
    <bpmn:sequenceFlow id="edge_6qQCyG" sourceRef="Task_WF_Extract" targetRef="Task_Load_KB_Analysis" />
    <bpmn:sequenceFlow id="edge_Task_WF_SendMissing-Gw_ValidationsJoinYDTBxT" sourceRef="Task_WF_SendMissing" targetRef="Event_end" />
    <bpmn:sequenceFlow id="edge_Gw_DocsComplete-Task_WF_ValidationsiG6pTa" sourceRef="Gw_DocsComplete" targetRef="Task_WF_Validations">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=vars.documentsComplete === true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="edge_UFNRzK" sourceRef="Gw_ReviewerOutcome" targetRef="Event_end">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=vars.outDecision2 === "reject" || vars.outDecision === "reject"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="edge_yCdVip" sourceRef="Gw_DocsComplete" targetRef="Task_WF_SendMissing">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=vars.documentsComplete === true</bpmn:conditionExpression>
