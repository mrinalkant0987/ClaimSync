        <uipath:inputOutput id="error18" name="Error" type="jsonSchema" elementId="Task_WF_SendMissing"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="outRequestMessage" name="out_RequestMessage" type="string" elementId="Task_WF_SendMissing" />
        <uipath:inputOutput id="error19" name="Error" type="jsonSchema" elementId="Task_WF_Validations"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="outValidationResults" name="out_ValidationResults" type="string" elementId="Task_WF_Validations" />
        <uipath:inputOutput id="outValidationPassed" name="out_ValidationPassed" type="boolean" elementId="Task_WF_Validations" />
        <uipath:inputOutput id="outClaimFolderPath" name="out_claimFolderPath" type="string" elementId="Task_WF_Monitor" />
        <uipath:inputOutput id="outClaimId" name="out_claimId" type="string" elementId="Task_WF_Monitor" />
        <uipath:inputOutput id="error2" name="Error" type="jsonSchema" elementId="Task_WF_Monitor"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="category" name="category" type="string" elementId="Task_AG_Analysis" />
        <uipath:inputOutput id="categoryConfidence" name="category_confidence" type="number" elementId="Task_AG_Analysis" />
        <uipath:inputOutput id="eligible" name="eligible" type="boolean" elementId="Task_AG_Analysis" />
        <uipath:inputOutput id="eligibilityReason" name="eligibility_reason" type="string" elementId="Task_AG_Analysis" />
        <uipath:inputOutput id="documentsComplete" name="documents_complete" type="boolean" elementId="Task_AG_Analysis" />
        <uipath:inputOutput id="missingDocuments" name="missing_documents" type="string" elementId="Task_AG_Analysis" />
        <uipath:inputOutput id="requestMessage" name="request_message" type="string" elementId="Task_AG_Analysis" />
        <uipath:inputOutput id="claimSummary" name="claim_summary" type="string" elementId="Task_AG_Analysis" />
        <uipath:inputOutput id="keyDocumentFacts" name="key_document_facts" type="string" elementId="Task_AG_Analysis" />
        <uipath:inputOutput id="analysisConfidence" name="analysis_confidence" type="number" elementId="Task_AG_Analysis" />
        <uipath:inputOutput id="error" name="Error" type="jsonSchema" elementId="Task_AG_Analysis"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="analysisCore" name="analysis_core" type="jsonSchema" elementId="Task_AG_Analysis"><![CDATA[{"type":"object","properties":{"category":{"type":"string","description":"Exactly one of: Healthcare, Vehicle, Travel. Never Generic. Determined by document evidence using dual-signal confirmation where possible.","enum":["Healthcare","Vehicle","Travel"]},"category_confidence":{"type":"number","description":"Confidence in category classification, 0.05 to 1.0, rounded to 2 decimal places. Starts at 1.0 and deductions are applied. Hard cap at 0.60 if KB is missing or under 50 chars."},"eligible":{"type":"boolean","description":"Whether the claim meets basic eligibility criteria based on document content and KB rules."},"eligibility_reason":{"type":"string","description":"Concise reason why eligible was set true or false. Must reference specific document evidence or KB rule applied."},"documents_complete":{"type":"boolean","description":"Whether all required documents for the identified category are present and readable in document_text_bundle."},"missing_documents":{"type":"string","description":"Pipe-separated list of missing required document types. Use empty string if documents_complete is true. Example: Travel insurance certificate|Booking confirmation|Incident report"},"request_message":{"type":"string","description":"Claimant-friendly message describing which documents are still needed and why. Use empty string if documents_complete is true."},"claim_summary":{"type":"string","description":"Concise 2-4 sentence claim summary covering category, eligibility, document status, and key facts. Must include KB note if KB was missing or partial. Must include confidence note if analysis_confidence is below 0.50."},"key_document_facts":{"type":"string","description":"Pipe-separated key facts explicitly found in the documents. Include claim amounts, dates, identifiers, and category-specific facts. Do NOT infer missing values."},"analysis_confidence":{"type":"number","description":"Overall analysis confidence after all deductions, 0.05 to 1.0, rounded to 2 decimal places. Starts at 1.0. Hard cap at 0.60 if KB missing. Minimum floor 0.05."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="summaryReport" name="summary_report" type="string" elementId="Task_AG_FinalSummary" />
        <uipath:inputOutput id="auditTrail" name="audit_trail" type="string" elementId="Task_AG_FinalSummary" />
        <uipath:inputOutput id="processingMetadata" name="processing_metadata" type="jsonSchema" elementId="Task_AG_FinalSummary"><![CDATA[{"type":"object","description":"Structured metadata object capturing key processing attributes for downstream record storage.","properties":{"claim_id":{"type":"string","description":"Echo of the input claim_id. Must match exactly."},"final_decision":{"type":"string","description":"Echo of the human reviewer's final_decision. Must match exactly — never modified."},"category":{"type":"string","description":"Claim category from AG_Claim_Analysis_Core. One of: Healthcare, Vehicle, Travel."},"fraud_risk_level":{"type":"string","description":"Fraud risk level from AG_Fraud_Risk. One of: low, medium, high."},"fraud_risk_score":{"type":"integer","description":"Numeric fraud risk score 0–100 from AG_Fraud_Risk."},"analysis_confidence":{"type":"number","description":"Analysis confidence score 0.0–1.0 from AG_Claim_Analysis_Core."},"recommendation_confidence":{"type":"number","description":"Recommendation confidence score 0.0–1.0 from AG_Decision_Support."},"summary_confidence":{"type":"number","description":"Overall settlement outcome confidence score 0.0–1.0. Calculated from recommendation_confidence adjusted for human-AI alignment and fraud risk. Higher when human decision aligns with AI recommendation. Capped at 0.70 when reviewer overrides AI recommendation. Floor: 0.20. Ceiling: 0.90."},"processed_at":{"type":"string","description":"UTC ISO 8601 timestamp of when this summary was generated. Format: yyyy-MM-ddTHH:mm:ssZ. Must reflect the actual current UTC time at generation — never hardcoded or copied from inputs."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="error12" name="Error" type="jsonSchema" elementId="Task_AG_FinalSummary"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="claimId3" name="claim_id" type="string" elementId="Task_AG_Decision_High" />
        <uipath:inputOutput id="recommendation3" name="recommendation" type="string" elementId="Task_AG_Decision_High" />
        <uipath:inputOutput id="recommendationConfidence3" name="recommendation_confidence" type="number" elementId="Task_AG_Decision_High" />
        <uipath:inputOutput id="recommendationRationale3" name="recommendation_rationale" type="string" elementId="Task_AG_Decision_High" />
        <uipath:inputOutput id="keyRiskFactors3" name="key_risk_factors" type="jsonSchema" subType="string" elementId="Task_AG_Decision_High"><![CDATA[{"type":"array","description":"Ordered list of the most significant risk factors influencing the recommendation. Include fraud signals, validation warnings, missing documents, and confidence gaps. List in descending order of severity. Empty array [] if no risk factors identified.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="suggestedSettlementNotes3" name="suggested_settlement_notes" type="string" elementId="Task_AG_Decision_High" />
        <uipath:inputOutput id="error16" name="Error" type="jsonSchema" elementId="Task_AG_Decision_High"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="decissionSupport" name="decission_support" type="jsonSchema" elementId="Task_AG_Decision_High"><![CDATA[{"type":"object","properties":{"claim_id":{"type":"string","description":"Echo of the input claim_id. Must match input exactly. Never modify or reformat."},"recommendation":{"type":"string","description":"AI-generated decision recommendation for the human reviewer. Exactly one of: Approve, Partial Approve, Reject, Request Documents. Determined by first-match priority logic. This is guidance only — the human reviewer makes the final decision via HITL.","enum":["Approve","Partial Approve","Reject","Request Documents"]},"recommendation_confidence":{"type":"number","description":"Confidence score 0.0–1.0 for the recommendation. Derived from the combination of analysis_confidence (from AG_Claim_Analysis_Core) and fraud risk score (from AG_Fraud_Risk). High fraud score suppresses confidence. Never use the field name 'confidence' — this field is always named 'recommendation_confidence'."},"recommendation_rationale":{"type":"string","description":"3–6 sentence explanation of the recommendation. Must reference: the claim category and eligibility outcome, the fraud risk level and score, the specific priority rule that triggered the recommendation, and any key risk factors. No speculation beyond input evidence."},"key_risk_factors":{"type":"array","description":"Ordered list of the most significant risk factors influencing the recommendation. Include fraud signals, validation warnings, missing documents, and confidence gaps. List in descending order of severity. Empty array [] if no risk factors identified.","items":{"type":"string"}},"suggested_settlement_notes":{"type":"string","description":"Optional guidance for the human reviewer on settlement considerations. Include: if Approve, note the claimed amount and any conditions; if Partial Approve, suggest what portion may be supportable and why; if Reject, state the disqualifying reason clearly; if Request Documents, list the specific documents needed. Keep to 2–4 sentences."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="claimId2" name="claim_id" type="string" elementId="Task_AG_Decision_Med" />
        <uipath:inputOutput id="recommendation2" name="recommendation" type="string" elementId="Task_AG_Decision_Med" />
        <uipath:inputOutput id="recommendationConfidence2" name="recommendation_confidence" type="number" elementId="Task_AG_Decision_Med" />
        <uipath:inputOutput id="recommendationRationale2" name="recommendation_rationale" type="string" elementId="Task_AG_Decision_Med" />
        <uipath:inputOutput id="keyRiskFactors2" name="key_risk_factors" type="jsonSchema" subType="string" elementId="Task_AG_Decision_Med"><![CDATA[{"type":"array","description":"Ordered list of the most significant risk factors influencing the recommendation. Include fraud signals, validation warnings, missing documents, and confidence gaps. List in descending order of severity. Empty array [] if no risk factors identified.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="suggestedSettlementNotes2" name="suggested_settlement_notes" type="string" elementId="Task_AG_Decision_Med" />
        <uipath:inputOutput id="error15" name="Error" type="jsonSchema" elementId="Task_AG_Decision_Med"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="decissionSupport2" name="decission_support" type="jsonSchema" elementId="Task_AG_Decision_Med"><![CDATA[{"type":"object","properties":{"claim_id":{"type":"string","description":"Echo of the input claim_id. Must match input exactly. Never modify or reformat."},"recommendation":{"type":"string","description":"AI-generated decision recommendation for the human reviewer. Exactly one of: Approve, Partial Approve, Reject, Request Documents. Determined by first-match priority logic. This is guidance only — the human reviewer makes the final decision via HITL.","enum":["Approve","Partial Approve","Reject","Request Documents"]},"recommendation_confidence":{"type":"number","description":"Confidence score 0.0–1.0 for the recommendation. Derived from the combination of analysis_confidence (from AG_Claim_Analysis_Core) and fraud risk score (from AG_Fraud_Risk). High fraud score suppresses confidence. Never use the field name 'confidence' — this field is always named 'recommendation_confidence'."},"recommendation_rationale":{"type":"string","description":"3–6 sentence explanation of the recommendation. Must reference: the claim category and eligibility outcome, the fraud risk level and score, the specific priority rule that triggered the recommendation, and any key risk factors. No speculation beyond input evidence."},"key_risk_factors":{"type":"array","description":"Ordered list of the most significant risk factors influencing the recommendation. Include fraud signals, validation warnings, missing documents, and confidence gaps. List in descending order of severity. Empty array [] if no risk factors identified.","items":{"type":"string"}},"suggested_settlement_notes":{"type":"string","description":"Optional guidance for the human reviewer on settlement considerations. Include: if Approve, note the claimed amount and any conditions; if Partial Approve, suggest what portion may be supportable and why; if Reject, state the disqualifying reason clearly; if Request Documents, list the specific documents needed. Keep to 2–4 sentences."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="claimId" name="claim_id" type="string" elementId="Task_AG_Decision_Low" />
        <uipath:inputOutput id="recommendation" name="recommendation" type="string" elementId="Task_AG_Decision_Low" />
        <uipath:inputOutput id="recommendationConfidence" name="recommendation_confidence" type="number" elementId="Task_AG_Decision_Low" />
