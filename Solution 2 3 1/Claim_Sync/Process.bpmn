        <uipath:inputOutput id="error6" name="Error" type="jsonSchema" elementId="Task_Load_KB_Fraud"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="outKnowledgeBundle2" name="out_KnowledgeBundle" type="string" elementId="Task_Load_KB_Fraud" />
        <uipath:inputOutput id="outKnowledgeLoadStatus2" name="out_KnowledgeLoadStatus" type="string" elementId="Task_Load_KB_Fraud" />
        <uipath:inputOutput id="outKnowledgeQualityHint2" name="out_KnowledgeQualityHint" type="string" elementId="Task_Load_KB_Fraud" />
        <uipath:inputOutput id="fraudRisk" name="fraudRisk" type="jsonSchema" elementId="Task_AG_Fraud"><![CDATA[{"type":"object","description":"Nested fraud risk assessment object. Always present in output.","properties":{"level":{"type":"string","description":"Final risk tier. Exactly one of: low, medium, high. Determined by composite score: 0–39=low, 40–69=medium, 70–100=high. Must be lowercase."},"score":{"type":"integer","description":"Composite fraud risk score 0–100. Sum of all triggered signal weights. Cap at 100."},"score_confidence":{"type":"number","description":"Confidence in the fraud score accuracy, 0.0–1.0. Based on evidence quality: number of signals detected, document completeness, validationResults completeness, and knowledge_bundle availability. High evidence quality = higher score_confidence. Floor: 0.20. Ceiling: 0.95."},"signals":{"type":"string","description":"Pipe-separated string of fraud signal codes triggered during analysis. Format: SIGNAL_CODE_1|SIGNAL_CODE_2|SIGNAL_CODE_3. Example: AMOUNT_ANOMALY|DATE_MISMATCH|DOC_SPARSE. Use empty string if no signals triggered. NOT an array — must be a single pipe-separated string."},"corroborating_signals":{"type":"string","description":"Pipe-separated string of BV validation warnings used as corroborating fraud evidence. Format: BV-003:WARN - document too short|BV-004:WARN - no amount detected. Use empty string if none. NOT an array — must be a single pipe-separated string."},"reasoning":{"type":"string","description":"Plain-language explanation of the fraud risk determination. 2–5 sentences. Must reference specific evidence from documents. Include score breakdown: e.g. Score: 55 = AMOUNT_ANOMALY(+20) + BV-004:WARN(+30) + DOC_SPARSE(+15). No speculation."},"recommended_action":{"type":"string","description":"Exactly one of: proceed_to_decision_support, escalate_to_claims_reviewer, escalate_to_fraud_specialist. Must align with level: low=proceed_to_decision_support, medium=escalate_to_claims_reviewer, high=escalate_to_fraud_specialist."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="error7" name="Error" type="jsonSchema" elementId="Task_AG_Fraud"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="error8" name="Error" type="jsonSchema" elementId="Task_Load_KB_Decision_High"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="outKnowledgeBundle3" name="out_KnowledgeBundle" type="string" elementId="Task_Load_KB_Decision_High" />
