    <bpmn:sequenceFlow id="Flow_fraud_to_risk" sourceRef="Task_AG_Fraud" targetRef="Gw_RiskLevel" />
    <bpmn:sequenceFlow id="Flow_risk_low" sourceRef="Gw_RiskLevel" targetRef="Task_Load_KB_Decision_Low">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=vars.fraudRisk.level == "low"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_risk_medium" sourceRef="Gw_RiskLevel" targetRef="Task_Load_KB_Decision_Med">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.fraudRisk.level == "medium"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_risk_high" sourceRef="Gw_RiskLevel" targetRef="Task_Load_KB_Decision_High">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.fraudRisk.level=="high"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_loadkb_low_to_decision" sourceRef="Task_Load_KB_Decision_Low" targetRef="Task_AG_Decision_Low" />
    <bpmn:sequenceFlow id="Flow_decision_low_to_finaljoin" sourceRef="Task_AG_Decision_Low" targetRef="Gw_FinalSummaryJoin" />
    <bpmn:sequenceFlow id="Flow_loadkb_med_to_decision" sourceRef="Task_Load_KB_Decision_Med" targetRef="Task_AG_Decision_Med" />
    <bpmn:sequenceFlow id="Flow_decision_med_to_reviewer" sourceRef="Task_AG_Decision_Med" targetRef="Task_HITL_Reviewer" />
    <bpmn:sequenceFlow id="Flow_reviewer_to_outcome" sourceRef="Task_HITL_Reviewer" targetRef="Gw_ReviewerOutcome" />
    <bpmn:sequenceFlow id="Flow_loadkb_high_to_decision" sourceRef="Task_Load_KB_Decision_High" targetRef="Task_AG_Decision_High" />
    <bpmn:sequenceFlow id="Flow_decision_high_to_fraudspec" sourceRef="Task_AG_Decision_High" targetRef="Task_HITL_FraudSpec" />
    <bpmn:sequenceFlow id="Flow_fraudspec_to_outcome" sourceRef="Task_HITL_FraudSpec" targetRef="Gw_ReviewerOutcome" />
    <bpmn:sequenceFlow id="Flow_outcome_proceed" sourceRef="Gw_ReviewerOutcome" targetRef="Gw_FinalSummaryJoin">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.outDecision === "approve" || vars.outDecision2 === "approve"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_finaljoin_to_loadkb_final" sourceRef="Gw_FinalSummaryJoin" targetRef="Task_Load_KB_Final" />
    <bpmn:sequenceFlow id="Flow_loadkb_to_final" sourceRef="Task_Load_KB_Final" targetRef="Task_AG_FinalSummary" />
    <bpmn:sequenceFlow id="Flow_finalsummary_to_update" sourceRef="Task_AG_FinalSummary" targetRef="Task_WF_UpdateRecord" />
    <bpmn:sequenceFlow id="Flow_update_to_archive" sourceRef="Task_WF_UpdateRecord" targetRef="Task_WF_Archive" />
    <bpmn:sequenceFlow id="Flow_archive_to_end" sourceRef="Task_WF_Archive" targetRef="Event_end" />
    <bpmn:sequenceFlow id="edge_Gw_SubmissionValid-Gw_InitJoinUcuboc" sourceRef="Gw_SubmissionValid" targetRef="Event_end">
