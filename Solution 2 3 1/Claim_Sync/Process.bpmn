        <uipath:inputOutput id="error9" name="Error" type="jsonSchema" elementId="Task_Load_KB_Decision_Med"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
