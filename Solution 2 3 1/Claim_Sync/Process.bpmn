        <uipath:inputOutput id="decissionSupport3" name="decission_support" type="jsonSchema" elementId="Task_AG_Decision_Low"><![CDATA[{"type":"object","properties":{"claim_id":{"type":"string","description":"Echo of the input claim_id. Must match input exactly. Never modify or reformat."},"recommendation":{"type":"string","description":"AI-generated decision recommendation for the human reviewer. Exactly one of: Approve, Partial Approve, Reject, Request Documents. Determined by first-match priority logic. This is guidance only — the human reviewer makes the final decision via HITL.","enum":["Approve","Partial Approve","Reject","Request Documents"]},"recommendation_confidence":{"type":"number","description":"Confidence score 0.0–1.0 for the recommendation. Derived from the combination of analysis_confidence (from AG_Claim_Analysis_Core) and fraud risk score (from AG_Fraud_Risk). High fraud score suppresses confidence. Never use the field name 'confidence' — this field is always named 'recommendation_confidence'."},"recommendation_rationale":{"type":"string","description":"3–6 sentence explanation of the recommendation. Must reference: the claim category and eligibility outcome, the fraud risk level and score, the specific priority rule that triggered the recommendation, and any key risk factors. No speculation beyond input evidence."},"key_risk_factors":{"type":"array","description":"Ordered list of the most significant risk factors influencing the recommendation. Include fraud signals, validation warnings, missing documents, and confidence gaps. List in descending order of severity. Empty array [] if no risk factors identified.","items":{"type":"string"}},"suggested_settlement_notes":{"type":"string","description":"Optional guidance for the human reviewer on settlement considerations. Include: if Approve, note the claimed amount and any conditions; if Partial Approve, suggest what portion may be supportable and why; if Reject, state the disqualifying reason clearly; if Request Documents, list the specific documents needed. Keep to 2–4 sentences."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
