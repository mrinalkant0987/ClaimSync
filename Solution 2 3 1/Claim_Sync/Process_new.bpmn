          <uipath:context>
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"args":{"type":"string"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"args":null}]]></uipath:input>
          <uipath:output name="DocRequestCount" type="number" source="=result.response" var="Var_DocRequestCount" />
        </uipath:mapping>
        <uipath:scriptVersion value="v3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_outcome_rework</bpmn:incoming>
      <bpmn:outgoing>Flow_reset_to_analysisjoin</bpmn:outgoing>
      <bpmn:script><![CDATA[return { response: 0 };]]></bpmn:script>
    </bpmn:scriptTask>
