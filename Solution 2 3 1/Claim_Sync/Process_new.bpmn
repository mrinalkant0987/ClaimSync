      <bpmn:outgoing>Flow_fraudspec_to_outcome</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gw_ReviewerOutcome" name="Reviewer Outcome" default="Flow_outcome_proceed">
