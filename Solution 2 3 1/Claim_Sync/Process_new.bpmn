            <uipath:input name="actions" value="[{&#34;actionName&#34;:&#34;approve_claim&#34;,&#34;label&#34;:&#34;Approve Claim&#34;},{&#34;actionName&#34;:&#34;reject_claim&#34;,&#34;label&#34;:&#34;Reject Claim&#34;},{&#34;actionName&#34;:&#34;return_for_rework&#34;,&#34;label&#34;:&#34;Return for Rework&#34;}]" />
            <uipath:input name="key" value="reviewer_decision_{{vars.Var_ClaimId}}" />
            <uipath:input name="taskTitle" value="Claims Reviewer Decision Required" />
          </uipath:context>
          <uipath:output name="Process response" type="Actions.HITL" var="Var_HITLOutcome" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_decision_med_to_reviewer</bpmn:incoming>
      <bpmn:outgoing>Flow_reviewer_to_outcome</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_AG_Decision_High" name="AG_Decision_Support (High)">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartAgentJob" version="v1" />
          <uipath:context>
            <uipath:input name="name" value="=bindings.Bind_Decision_Name" />
            <uipath:input name="folderPath" value="=bindings.Bind_Decision_Folder" />
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"claim_id":{"type":"string","title":"claim_id"},"analysis_result_json":{"type":"string","title":"analysis_result_json"},"fraud_risk_json":{"type":"string","title":"fraud_risk_json"},"reviewer_package":{"type":"string","title":"reviewer_package"},"knowledge_bundle":{"type":"string","title":"knowledge_bundle"}},"required":["claim_id","analysis_result_json","fraud_risk_json"]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"claim_id":"=vars.Var_ClaimId","analysis_result_json":"=vars.Var_AnalysisResult","fraud_risk_json":"=vars.Var_FraudRiskResult","reviewer_package":null,"knowledge_bundle":"=js: (function(){try{var r=JSON.parse(vars.Var_JobResponse||'{}');return r.out_knowledge_bundle||'';}catch(e){return'';}})()"}]]></uipath:input>
          <uipath:output name="Error" type="jsonSchema" source="=Error" var="error4" />
          <uipath:output name="claim_id" type="string" source="=claim_id" var="claimId3" />
          <uipath:output name="recommendation" type="string" source="=recommendation" var="recommendation3" />
          <uipath:output name="recommendation_confidence" type="number" source="=recommendation_confidence" var="recommendationConfidence3" />
          <uipath:output name="recommendation_rationale" type="string" source="=recommendation_rationale" var="recommendationRationale3" />
          <uipath:output name="key_risk_factors" type="jsonSchema" subType="string" source="=key_risk_factors" var="keyRiskFactors3" />
          <uipath:output name="suggested_settlement_notes" type="string" source="=suggested_settlement_notes" var="suggestedSettlementNotes3" />
          <uipath:output name="decission_support" type="jsonSchema" source="=decission_support" var="decissionSupport3" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_risk_high</bpmn:incoming>
      <bpmn:outgoing>Flow_decision_high_to_fraudspec</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_HITL_FraudSpec" name="HITL Fraud Specialist">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Actions.HITL" version="v1" />
          <uipath:context>
            <uipath:input name="appId" value="ClaimsProcessingHITL" />
            <uipath:input name="appVersion" value="1.0" />
            <uipath:input name="actions" value="[{&#34;actionName&#34;:&#34;clear_fraud&#34;,&#34;label&#34;:&#34;Clear Fraud Concern&#34;},{&#34;actionName&#34;:&#34;confirm_fraud&#34;,&#34;label&#34;:&#34;Confirm Fraud&#34;},{&#34;actionName&#34;:&#34;escalate&#34;,&#34;label&#34;:&#34;Escalate to Legal&#34;}]" />
            <uipath:input name="key" value="fraud_review_{{vars.Var_ClaimId}}" />
            <uipath:input name="taskTitle" value="Fraud Specialist Review Required" />
          </uipath:context>
          <uipath:output name="Process response" type="Actions.HITL" var="Var_HITLOutcome" />
        </uipath:activity>
      </bpmn:extensionElements>
