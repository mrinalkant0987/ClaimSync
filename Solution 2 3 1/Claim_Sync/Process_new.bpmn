<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:uipath="http://uipath.org/schema/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="x-uipath-initial-diagram" targetNamespace="http://www.omg.org/spec/BPMN/20100524/MODEL" exporter="UiPath Studio Web (https://uipath.com)" exporterVersion="b52d90e7">
  <bpmn:process id="Process_1" name="Process_new">
    <bpmn:documentation>Claim Settlement Process</bpmn:documentation>
    <bpmn:extensionElements>
      <uipath:variables version="v1">
        <uipath:inputOutput id="Var_ClaimId" name="ClaimId" type="string" />
        <uipath:inputOutput id="Var_ClaimFolderPath" name="ClaimFolderPath" type="string" />
        <uipath:inputOutput id="Var_SubmissionValid" name="SubmissionValid" type="boolean" default="true" />
        <uipath:inputOutput id="Var_DocTextBundle" name="DocTextBundle" type="string" />
        <uipath:inputOutput id="Var_ExtractionNotes" name="ExtractionNotes" type="string" />
        <uipath:inputOutput id="Var_ExtractedData" name="ExtractedData" type="string" />
        <uipath:inputOutput id="Var_KnowledgeBundle" name="KnowledgeBundle" type="string" />
        <uipath:inputOutput id="Var_KnowledgeQualityHint" name="KnowledgeQualityHint" type="string" />
        <uipath:inputOutput id="Var_DocRequestCount" name="DocRequestCount" type="number" default="0" />
        <uipath:inputOutput id="Var_AnalysisResult" name="AnalysisResult" type="string" />
        <uipath:inputOutput id="Var_DocumentsComplete" name="DocumentsComplete" type="boolean" default="true" />
        <uipath:inputOutput id="Var_Category" name="Category" type="string" />
        <uipath:inputOutput id="Var_ValidationResults" name="ValidationResults" type="string" />
        <uipath:inputOutput id="Var_FraudRiskResult" name="FraudRiskResult" type="string" />
        <uipath:inputOutput id="Var_FraudRiskLevel" name="FraudRiskLevel" type="string" default="low" />
        <uipath:inputOutput id="Var_HITLOutcome" name="HITLOutcome" type="string" />
        <uipath:inputOutput id="Var_DecisionResult" name="DecisionResult" type="string" />
        <uipath:inputOutput id="Var_FinalSummaryResult" name="FinalSummaryResult" type="string" />
        <uipath:inputOutput id="Var_JobResponse" name="JobResponse" type="string" />
        <uipath:inputOutput id="error" name="Error" type="jsonSchema" elementId="Task_AG_Analysis"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="category" name="category" type="string" elementId="Task_AG_Analysis" />
        <uipath:inputOutput id="categoryConfidence" name="category_confidence" type="number" elementId="Task_AG_Analysis" />
        <uipath:inputOutput id="eligible" name="eligible" type="boolean" elementId="Task_AG_Analysis" />
        <uipath:inputOutput id="eligibilityReason" name="eligibility_reason" type="string" elementId="Task_AG_Analysis" />
        <uipath:inputOutput id="documentsComplete" name="documents_complete" type="boolean" elementId="Task_AG_Analysis" />
        <uipath:inputOutput id="missingDocuments" name="missing_documents" type="string" elementId="Task_AG_Analysis" />
        <uipath:inputOutput id="requestMessage" name="request_message" type="string" elementId="Task_AG_Analysis" />
        <uipath:inputOutput id="claimSummary" name="claim_summary" type="string" elementId="Task_AG_Analysis" />
        <uipath:inputOutput id="keyDocumentFacts" name="key_document_facts" type="string" elementId="Task_AG_Analysis" />
        <uipath:inputOutput id="analysisConfidence" name="analysis_confidence" type="number" elementId="Task_AG_Analysis" />
        <uipath:inputOutput id="analysisCore" name="analysis_core" type="jsonSchema" elementId="Task_AG_Analysis"><![CDATA[{"type":"object","properties":{"category":{"type":"string","description":"Exactly one of: Healthcare, Vehicle, Travel. Never Generic. Determined by document evidence using dual-signal confirmation where possible.","enum":["Healthcare","Vehicle","Travel"]},"category_confidence":{"type":"number","description":"Confidence in category classification, 0.05 to 1.0, rounded to 2 decimal places. Starts at 1.0 and deductions are applied. Hard cap at 0.60 if KB is missing or under 50 chars."},"eligible":{"type":"boolean","description":"Whether the claim meets basic eligibility criteria based on document content and KB rules."},"eligibility_reason":{"type":"string","description":"Concise reason why eligible was set true or false. Must reference specific document evidence or KB rule applied."},"documents_complete":{"type":"boolean","description":"Whether all required documents for the identified category are present and readable in document_text_bundle."},"missing_documents":{"type":"string","description":"Pipe-separated list of missing required document types. Use empty string if documents_complete is true. Example: Travel insurance certificate|Booking confirmation|Incident report"},"request_message":{"type":"string","description":"Claimant-friendly message describing which documents are still needed and why. Use empty string if documents_complete is true."},"claim_summary":{"type":"string","description":"Concise 2-4 sentence claim summary covering category, eligibility, document status, and key facts. Must include KB note if KB was missing or partial. Must include confidence note if analysis_confidence is below 0.50."},"key_document_facts":{"type":"string","description":"Pipe-separated key facts explicitly found in the documents. Include claim amounts, dates, identifiers, and category-specific facts. Do NOT infer missing values."},"analysis_confidence":{"type":"number","description":"Overall analysis confidence after all deductions, 0.05 to 1.0, rounded to 2 decimal places. Starts at 1.0. Hard cap at 0.60 if KB missing. Minimum floor 0.05."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="error5" name="Error" type="jsonSchema" elementId="Task_AG_FinalSummary"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="summaryReport" name="summary_report" type="string" elementId="Task_AG_FinalSummary" />
        <uipath:inputOutput id="auditTrail" name="audit_trail" type="string" elementId="Task_AG_FinalSummary" />
        <uipath:inputOutput id="processingMetadata" name="processing_metadata" type="jsonSchema" elementId="Task_AG_FinalSummary"><![CDATA[{"type":"object","description":"Structured metadata object capturing key processing attributes for downstream record storage.","properties":{"claim_id":{"type":"string","description":"Echo of the input claim_id. Must match exactly."},"final_decision":{"type":"string","description":"Echo of the human reviewer's final_decision. Must match exactly — never modified."},"category":{"type":"string","description":"Claim category from AG_Claim_Analysis_Core. One of: Healthcare, Vehicle, Travel."},"fraud_risk_level":{"type":"string","description":"Fraud risk level from AG_Fraud_Risk. One of: low, medium, high."},"fraud_risk_score":{"type":"integer","description":"Numeric fraud risk score 0–100 from AG_Fraud_Risk."},"analysis_confidence":{"type":"number","description":"Analysis confidence score 0.0–1.0 from AG_Claim_Analysis_Core."},"recommendation_confidence":{"type":"number","description":"Recommendation confidence score 0.0–1.0 from AG_Decision_Support."},"summary_confidence":{"type":"number","description":"Overall settlement outcome confidence score 0.0–1.0. Calculated from recommendation_confidence adjusted for human-AI alignment and fraud risk. Higher when human decision aligns with AI recommendation. Capped at 0.70 when reviewer overrides AI recommendation. Floor: 0.20. Ceiling: 0.90."},"processed_at":{"type":"string","description":"UTC ISO 8601 timestamp of when this summary was generated. Format: yyyy-MM-ddTHH:mm:ssZ. Must reflect the actual current UTC time at generation — never hardcoded or copied from inputs."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="error6" name="Error" type="jsonSchema" elementId="Task_AG_Fraud"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="fraudRisk" name="fraudRisk" type="jsonSchema" elementId="Task_AG_Fraud"><![CDATA[{"type":"object","description":"Nested fraud risk assessment object. Always present in output.","properties":{"level":{"type":"string","description":"Final risk tier. Exactly one of: low, medium, high. Determined by composite score: 0–39=low, 40–69=medium, 70–100=high. Must be lowercase."},"score":{"type":"integer","description":"Composite fraud risk score 0–100. Sum of all triggered signal weights. Cap at 100."},"score_confidence":{"type":"number","description":"Confidence in the fraud score accuracy, 0.0–1.0. Based on evidence quality: number of signals detected, document completeness, validationResults completeness, and knowledge_bundle availability. High evidence quality = higher score_confidence. Floor: 0.20. Ceiling: 0.95."},"signals":{"type":"string","description":"Pipe-separated string of fraud signal codes triggered during analysis. Format: SIGNAL_CODE_1|SIGNAL_CODE_2|SIGNAL_CODE_3. Example: AMOUNT_ANOMALY|DATE_MISMATCH|DOC_SPARSE. Use empty string if no signals triggered. NOT an array — must be a single pipe-separated string."},"corroborating_signals":{"type":"string","description":"Pipe-separated string of BV validation warnings used as corroborating fraud evidence. Format: BV-003:WARN - document too short|BV-004:WARN - no amount detected. Use empty string if none. NOT an array — must be a single pipe-separated string."},"reasoning":{"type":"string","description":"Plain-language explanation of the fraud risk determination. 2–5 sentences. Must reference specific evidence from documents. Include score breakdown: e.g. Score: 55 = AMOUNT_ANOMALY(+20) + BV-004:WARN(+30) + DOC_SPARSE(+15). No speculation."},"recommended_action":{"type":"string","description":"Exactly one of: proceed_to_decision_support, escalate_to_claims_reviewer, escalate_to_fraud_specialist. Must align with level: low=proceed_to_decision_support, medium=escalate_to_claims_reviewer, high=escalate_to_fraud_specialist."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="error2" name="Error" type="jsonSchema" elementId="Task_AG_Decision_Low"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="claimId" name="claim_id" type="string" elementId="Task_AG_Decision_Low" />
        <uipath:inputOutput id="recommendation" name="recommendation" type="string" elementId="Task_AG_Decision_Low" />
        <uipath:inputOutput id="recommendationConfidence" name="recommendation_confidence" type="number" elementId="Task_AG_Decision_Low" />
        <uipath:inputOutput id="recommendationRationale" name="recommendation_rationale" type="string" elementId="Task_AG_Decision_Low" />
        <uipath:inputOutput id="keyRiskFactors" name="key_risk_factors" type="jsonSchema" subType="string" elementId="Task_AG_Decision_Low"><![CDATA[{"type":"array","description":"Ordered list of the most significant risk factors influencing the recommendation. Include fraud signals, validation warnings, missing documents, and confidence gaps. List in descending order of severity. Empty array [] if no risk factors identified.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="suggestedSettlementNotes" name="suggested_settlement_notes" type="string" elementId="Task_AG_Decision_Low" />
        <uipath:inputOutput id="decissionSupport" name="decission_support" type="jsonSchema" elementId="Task_AG_Decision_Low"><![CDATA[{"type":"object","properties":{"claim_id":{"type":"string","description":"Echo of the input claim_id. Must match input exactly. Never modify or reformat."},"recommendation":{"type":"string","description":"AI-generated decision recommendation for the human reviewer. Exactly one of: Approve, Partial Approve, Reject, Request Documents. Determined by first-match priority logic. This is guidance only — the human reviewer makes the final decision via HITL.","enum":["Approve","Partial Approve","Reject","Request Documents"]},"recommendation_confidence":{"type":"number","description":"Confidence score 0.0–1.0 for the recommendation. Derived from the combination of analysis_confidence (from AG_Claim_Analysis_Core) and fraud risk score (from AG_Fraud_Risk). High fraud score suppresses confidence. Never use the field name 'confidence' — this field is always named 'recommendation_confidence'."},"recommendation_rationale":{"type":"string","description":"3–6 sentence explanation of the recommendation. Must reference: the claim category and eligibility outcome, the fraud risk level and score, the specific priority rule that triggered the recommendation, and any key risk factors. No speculation beyond input evidence."},"key_risk_factors":{"type":"array","description":"Ordered list of the most significant risk factors influencing the recommendation. Include fraud signals, validation warnings, missing documents, and confidence gaps. List in descending order of severity. Empty array [] if no risk factors identified.","items":{"type":"string"}},"suggested_settlement_notes":{"type":"string","description":"Optional guidance for the human reviewer on settlement considerations. Include: if Approve, note the claimed amount and any conditions; if Partial Approve, suggest what portion may be supportable and why; if Reject, state the disqualifying reason clearly; if Request Documents, list the specific documents needed. Keep to 2–4 sentences."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="error3" name="Error" type="jsonSchema" elementId="Task_AG_Decision_Med"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="claimId2" name="claim_id" type="string" elementId="Task_AG_Decision_Med" />
        <uipath:inputOutput id="recommendation2" name="recommendation" type="string" elementId="Task_AG_Decision_Med" />
        <uipath:inputOutput id="recommendationConfidence2" name="recommendation_confidence" type="number" elementId="Task_AG_Decision_Med" />
        <uipath:inputOutput id="recommendationRationale2" name="recommendation_rationale" type="string" elementId="Task_AG_Decision_Med" />
        <uipath:inputOutput id="keyRiskFactors2" name="key_risk_factors" type="jsonSchema" subType="string" elementId="Task_AG_Decision_Med"><![CDATA[{"type":"array","description":"Ordered list of the most significant risk factors influencing the recommendation. Include fraud signals, validation warnings, missing documents, and confidence gaps. List in descending order of severity. Empty array [] if no risk factors identified.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="suggestedSettlementNotes2" name="suggested_settlement_notes" type="string" elementId="Task_AG_Decision_Med" />
        <uipath:inputOutput id="decissionSupport2" name="decission_support" type="jsonSchema" elementId="Task_AG_Decision_Med"><![CDATA[{"type":"object","properties":{"claim_id":{"type":"string","description":"Echo of the input claim_id. Must match input exactly. Never modify or reformat."},"recommendation":{"type":"string","description":"AI-generated decision recommendation for the human reviewer. Exactly one of: Approve, Partial Approve, Reject, Request Documents. Determined by first-match priority logic. This is guidance only — the human reviewer makes the final decision via HITL.","enum":["Approve","Partial Approve","Reject","Request Documents"]},"recommendation_confidence":{"type":"number","description":"Confidence score 0.0–1.0 for the recommendation. Derived from the combination of analysis_confidence (from AG_Claim_Analysis_Core) and fraud risk score (from AG_Fraud_Risk). High fraud score suppresses confidence. Never use the field name 'confidence' — this field is always named 'recommendation_confidence'."},"recommendation_rationale":{"type":"string","description":"3–6 sentence explanation of the recommendation. Must reference: the claim category and eligibility outcome, the fraud risk level and score, the specific priority rule that triggered the recommendation, and any key risk factors. No speculation beyond input evidence."},"key_risk_factors":{"type":"array","description":"Ordered list of the most significant risk factors influencing the recommendation. Include fraud signals, validation warnings, missing documents, and confidence gaps. List in descending order of severity. Empty array [] if no risk factors identified.","items":{"type":"string"}},"suggested_settlement_notes":{"type":"string","description":"Optional guidance for the human reviewer on settlement considerations. Include: if Approve, note the claimed amount and any conditions; if Partial Approve, suggest what portion may be supportable and why; if Reject, state the disqualifying reason clearly; if Request Documents, list the specific documents needed. Keep to 2–4 sentences."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="error4" name="Error" type="jsonSchema" elementId="Task_AG_Decision_High"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="claimId3" name="claim_id" type="string" elementId="Task_AG_Decision_High" />
        <uipath:inputOutput id="recommendation3" name="recommendation" type="string" elementId="Task_AG_Decision_High" />
        <uipath:inputOutput id="recommendationConfidence3" name="recommendation_confidence" type="number" elementId="Task_AG_Decision_High" />
        <uipath:inputOutput id="recommendationRationale3" name="recommendation_rationale" type="string" elementId="Task_AG_Decision_High" />
        <uipath:inputOutput id="keyRiskFactors3" name="key_risk_factors" type="jsonSchema" subType="string" elementId="Task_AG_Decision_High"><![CDATA[{"type":"array","description":"Ordered list of the most significant risk factors influencing the recommendation. Include fraud signals, validation warnings, missing documents, and confidence gaps. List in descending order of severity. Empty array [] if no risk factors identified.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="suggestedSettlementNotes3" name="suggested_settlement_notes" type="string" elementId="Task_AG_Decision_High" />
        <uipath:inputOutput id="decissionSupport3" name="decission_support" type="jsonSchema" elementId="Task_AG_Decision_High"><![CDATA[{"type":"object","properties":{"claim_id":{"type":"string","description":"Echo of the input claim_id. Must match input exactly. Never modify or reformat."},"recommendation":{"type":"string","description":"AI-generated decision recommendation for the human reviewer. Exactly one of: Approve, Partial Approve, Reject, Request Documents. Determined by first-match priority logic. This is guidance only — the human reviewer makes the final decision via HITL.","enum":["Approve","Partial Approve","Reject","Request Documents"]},"recommendation_confidence":{"type":"number","description":"Confidence score 0.0–1.0 for the recommendation. Derived from the combination of analysis_confidence (from AG_Claim_Analysis_Core) and fraud risk score (from AG_Fraud_Risk). High fraud score suppresses confidence. Never use the field name 'confidence' — this field is always named 'recommendation_confidence'."},"recommendation_rationale":{"type":"string","description":"3–6 sentence explanation of the recommendation. Must reference: the claim category and eligibility outcome, the fraud risk level and score, the specific priority rule that triggered the recommendation, and any key risk factors. No speculation beyond input evidence."},"key_risk_factors":{"type":"array","description":"Ordered list of the most significant risk factors influencing the recommendation. Include fraud signals, validation warnings, missing documents, and confidence gaps. List in descending order of severity. Empty array [] if no risk factors identified.","items":{"type":"string"}},"suggested_settlement_notes":{"type":"string","description":"Optional guidance for the human reviewer on settlement considerations. Include: if Approve, note the claimed amount and any conditions; if Partial Approve, suggest what portion may be supportable and why; if Reject, state the disqualifying reason clearly; if Request Documents, list the specific documents needed. Keep to 2–4 sentences."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
      </uipath:variables>
      <uipath:bindings version="v1">
        <uipath:binding id="Bind_Analysis_Name" default="AG_Claim_Analysis_Core" resource="process" propertyAttribute="name" />
        <uipath:binding id="Bind_Analysis_Folder" default="mrinal.kant@infosys.com&#39;s workspace/Debug_Solution" resource="process" propertyAttribute="folderPath" />
        <uipath:binding id="Bind_Fraud_Name" default="AG_Fraud_Risk" resource="process" propertyAttribute="name" />
        <uipath:binding id="Bind_Fraud_Folder" default="" resource="process" propertyAttribute="folderPath" />
        <uipath:binding id="Bind_Decision_Name" default="AG_Decision_Support" resource="process" propertyAttribute="name" />
        <uipath:binding id="Bind_Decision_Folder" default="" resource="process" propertyAttribute="folderPath" />
        <uipath:binding id="Bind_Final_Name" default="AG_Final_Summary" resource="process" propertyAttribute="name" />
        <uipath:binding id="Bind_Final_Folder" default="" resource="process" propertyAttribute="folderPath" />
      </uipath:bindings>
      <uipath:migrationVersion version="15" />
      <uipath:intsvcActivityConfig version="v2" />
    </bpmn:extensionElements>
    <bpmn:startEvent id="Event_start" name="Start event">
      <bpmn:extensionElements>
        <uipath:entryPointId value="e33dd2dc-5fb2-4332-b458-ca30f5adef63" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_start_to_init</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:scriptTask id="Task_InitVars" name="Initialize Variables" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
          <uipath:context>
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"args":{"type":"string"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"args":null}]]></uipath:input>
          <uipath:output name="SubmissionValid" type="boolean" source="=result.submissionValid" var="Var_SubmissionValid" />
          <uipath:output name="DocumentsComplete" type="boolean" source="=result.documentsComplete" var="Var_DocumentsComplete" />
          <uipath:output name="FraudRiskLevel" type="string" source="=result.fraudRiskLevel" var="Var_FraudRiskLevel" />
          <uipath:output name="DocRequestCount" type="number" source="=result.docRequestCount" var="Var_DocRequestCount" />
        </uipath:mapping>
        <uipath:scriptVersion value="v3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_start_to_init</bpmn:incoming>
      <bpmn:outgoing>Flow_init_to_monitor</bpmn:outgoing>
      <bpmn:script><![CDATA[return { submissionValid: true, documentsComplete: true, fraudRiskLevel: "low", docRequestCount: 0 };]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:serviceTask id="Task_WF_Monitor" name="WF_Monitor_Claim_Intake">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartJob" version="v1" />
          <uipath:context>
            <uipath:input name="releaseKey" value="" />
            <uipath:input name="folderId" value="" />
            <uipath:input name="folderPath" value="" />
            <uipath:input name="name" value="WF_Monitor_Claim_Intake" />
            <uipath:input name="JobArguments" type="json"><![CDATA[{"in_rootFolderPath":"C:\\Users\\mrinal.kant\\Documents\\Usecase\\Solution 2 Copy\\Claims"}]]></uipath:input>
          </uipath:context>
          <uipath:output name="Process response" type="Orchestrator.RunJob" var="Var_JobResponse" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_init_to_monitor</bpmn:incoming>
      <bpmn:outgoing>Flow_monitor_to_initjoin</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gw_InitJoin" name="Intake Join" default="Flow_initjoin_to_init">
      <bpmn:incoming>Flow_monitor_to_initjoin</bpmn:incoming>
      <bpmn:incoming>Flow_hitl_sub_to_initjoin</bpmn:incoming>
      <bpmn:outgoing>Flow_initjoin_to_init</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_WF_Initialize" name="WF_Initialize_Claim_Record">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartJob" version="v1" />
          <uipath:context>
            <uipath:input name="releaseKey" value="" />
            <uipath:input name="folderId" value="" />
            <uipath:input name="folderPath" value="" />
            <uipath:input name="name" value="WF_Initialize_Claim_Record" />
            <uipath:input name="JobArguments" type="json"><![CDATA[{"in_claim_folder_path":"=vars.Var_ClaimFolderPath"}]]></uipath:input>
          </uipath:context>
          <uipath:output name="Process response" type="Orchestrator.RunJob" var="Var_JobResponse" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_initjoin_to_init</bpmn:incoming>
      <bpmn:outgoing>Flow_init_to_subgw</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gw_SubmissionValid" name="Submission Valid?" default="Flow_valid_true">
      <bpmn:incoming>Flow_init_to_subgw</bpmn:incoming>
      <bpmn:outgoing>Flow_valid_true</bpmn:outgoing>
      <bpmn:outgoing>Flow_valid_false</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_WF_Extract" name="WF_Read_And_Extract_Document_Text">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartJob" version="v1" />
          <uipath:context>
            <uipath:input name="releaseKey" value="" />
            <uipath:input name="folderId" value="" />
            <uipath:input name="folderPath" value="" />
            <uipath:input name="name" value="WF_Read_And_Extract_Document_Text" />
            <uipath:input name="JobArguments" type="json"><![CDATA[{"in_claimFolderPath":"=vars.Var_ClaimFolderPath","in_claimId":"=vars.Var_ClaimId"}]]></uipath:input>
          </uipath:context>
          <uipath:output name="Process response" type="Orchestrator.RunJob" var="Var_JobResponse" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_valid_true</bpmn:incoming>
      <bpmn:outgoing>Flow_extract_to_analysisjoin</bpmn:outgoing>
