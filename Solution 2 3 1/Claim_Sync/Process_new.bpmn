    <bpmn:serviceTask id="Task_WF_Load_Agent_Knowledge_Analysis" name="WF_Load_Agent_Knowledge (AG_Claim_Analysis_Core)">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartJob" version="v1" />
          <uipath:context>
            <uipath:input name="releaseKey" value="" />
