    <x:Property Name="in_ClaimId" Type="InArgument(x:String)" />
    <x:Property Name="in_ClaimFolderPath" Type="InArgument(x:String)" />
    <x:Property Name="in_MissingDocuments" Type="InArgument(scg:List(x:String))" />
    <x:Property Name="out_RequestMessage" Type="OutArgument(x:String)" />
  </x:Members>
  <TextExpression.NamespacesForImplementation>
    <scg:List x:TypeArguments="x:String" Capacity="14">
