    <Assign x:TypeArguments="x:String" DisplayName="[Step 5] Finalise out_ValidationResults" sap2010:WorkflowViewState.IdRef="Assign_15" To="[out_ValidationResults]" Value="[If(String.IsNullOrEmpty(out_ValidationResults), &quot;No validations executed&quot;, out_ValidationResults)]" />
    <If Condition="[Not String.IsNullOrEmpty(out_ValidationResults) AndAlso (out_ValidationResults.Contains(&quot;Missing&quot;) OrElse out_ValidationResults.Contains(&quot;TooShort&quot;) OrElse out_ValidationResults.Contains(&quot;NoDocuments&quot;))]" DisplayName="[Step 6] Determine Overall Status" sap2010:WorkflowViewState.IdRef="If_6">
