      <If.Else>
        <Assign x:TypeArguments="x:String" DisplayName="Append: TextMissing" sap2010:WorkflowViewState.IdRef="Assign_10" To="[out_ValidationResults]" Value="[out_ValidationResults &amp; &quot;; TextMissing&quot;]" />
