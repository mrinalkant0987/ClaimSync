    <If Condition="[Not String.IsNullOrEmpty(in_ClaimFolderPath)]" DisplayName="Audit Log" sap2010:WorkflowViewState.IdRef="If_Audit">
      <sap:WorkflowViewStateService.ViewState>
        <scg:Dictionary x:TypeArguments="x:String, x:Object">
