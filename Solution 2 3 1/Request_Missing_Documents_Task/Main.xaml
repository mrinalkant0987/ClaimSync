      <If.Then>
        <Sequence DisplayName="Write Audit" sap2010:WorkflowViewState.IdRef="Sequence_Audit">
          <sap:WorkflowViewStateService.ViewState>
            <scg:Dictionary x:TypeArguments="x:String, x:Object">
              <x:Boolean x:Key="IsExpanded">True</x:Boolean>
            </scg:Dictionary>
          </sap:WorkflowViewStateService.ViewState>
          <Assign DisplayName="Build Audit File Path" sap2010:WorkflowViewState.IdRef="Assign_AuditPath">
            <Assign.To>
              <OutArgument x:TypeArguments="x:String">[AuditFilePath]</OutArgument>
            </Assign.To>
            <Assign.Value>
              <InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(in_ClaimFolderPath, System.IO.Path.GetFileName(in_ClaimFolderPath) + ".txt")]</InArgument>
            </Assign.Value>
          </Assign>
          <Assign DisplayName="Build Audit Entry" sap2010:WorkflowViewState.IdRef="Assign_AuditEntry">
            <Assign.To>
              <OutArgument x:TypeArguments="x:String">[AuditEntry]</OutArgument>
            </Assign.To>
            <Assign.Value>
              <InArgument x:TypeArguments="x:String">["------------------------------------------" + Environment.NewLine + "Request_Missing_Documents_Task" + Environment.NewLine + "------------------------------------------" + Environment.NewLine + "in_ClaimFolderPath : " + in_ClaimFolderPath + Environment.NewLine + "status : triggered" + Environment.NewLine + "timestamp : " + Now.ToString("yyyy-MM-dd HH:mm:ss") + Environment.NewLine + Environment.NewLine]</InArgument>
            </Assign.Value>
          </Assign>
          <TryCatch DisplayName="TryCatch - Write Audit" sap2010:WorkflowViewState.IdRef="TryCatch_Audit">
            <TryCatch.Try>
              <InvokeMethod DisplayName="Append Audit Entry" MethodName="AppendAllText" TargetType="{x:Type sio:File}">
                <InArgument x:TypeArguments="x:String">[AuditFilePath]</InArgument>
                <InArgument x:TypeArguments="x:String">[AuditEntry]</InArgument>
              </InvokeMethod>
            </TryCatch.Try>
            <TryCatch.Catches>
              <Catch x:TypeArguments="s:Exception" sap2010:WorkflowViewState.IdRef="Catch_Audit">
                <ActivityAction x:TypeArguments="s:Exception">
                  <ActivityAction.Argument>
                    <DelegateInArgument x:TypeArguments="s:Exception" Name="AuditEx" />
                  </ActivityAction.Argument>
                  <Sequence DisplayName="Audit Write Failed - Ignore" sap2010:WorkflowViewState.IdRef="Sequence_AuditFailed">
                    <sap:WorkflowViewStateService.ViewState>
                      <scg:Dictionary x:TypeArguments="x:String, x:Object">
                        <x:Boolean x:Key="IsExpanded">True</x:Boolean>
                      </scg:Dictionary>
                    </sap:WorkflowViewStateService.ViewState>
                    <ui:LogMessage DisplayName="Log Audit Write Error" Level="Warn" Message="[&quot;[Request_Missing_Documents_Task] Audit write failed: &quot; + AuditEx.Message]" sap2010:WorkflowViewState.IdRef="LogMessage_AuditError" />
                  </Sequence>
                </ActivityAction>
              </Catch>
            </TryCatch.Catches>
          </TryCatch>
