    <x:Property Name="out_IsIdProofAvailable" Type="OutArgument(x:Boolean)" />
    <x:Property Name="out_AreAllMandatoryDocumentsAvailable" Type="OutArgument(x:Boolean)" />
    <x:Property Name="out_PolicyCategory" Type="OutArgument(x:String)" />
  </x:Members>
